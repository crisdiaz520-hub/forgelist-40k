{
  "name": "forgelist-40k",
  "version": "0.1.0",
  "private": true,
  "description": "ForgeList 40K installable desktop and Android package.",
  "main": "electron/main.js",
  "scripts": {
    "prepare:web": "node scripts/prepare-web.mjs",
    "desktop": "npm run prepare:web && electron .",
    "build:exe": "npm run prepare:web && electron-builder --win nsis",
    "android:init": "npm run prepare:web && cap add android",
    "android:sync": "npm run prepare:web && cap sync android",
    "build:apk": "npm run android:sync && node scripts/build-android-apk.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/cli": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "electron": "^33.0.0"
  },
  "devDependencies": {
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.forgelist40k.app",
    "productName": "ForgeList 40K",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/web/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
